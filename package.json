{
  "name": "ari",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:api & npm run dev:web",
    "dev:web": "npm --workspace @ari/web run dev",
    "dev:api": "npm --workspace @ari/api run dev",
    "dev:worker": "npm --workspace @ari/worker run dev",
    "build": "npm run typecheck && npm --workspace @ari/web run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "lint": "npm run typecheck && npm run test"
  },
  "dependencies": {
    "@clerk/backend": "^3.4.4",
    "@clerk/nextjs": "^7.3.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@hookform/resolvers": "^3.10.0",
    "@prisma/client": "^5.22.0",
    "@tanstack/react-query": "^5.90.10",
    "@temporalio/client": "^1.17.0",
    "@temporalio/worker": "^1.17.0",
    "@temporalio/workflow": "^1.17.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "fastify": "^5.8.5",
    "lucide-react": "^0.475.0",
    "next": "^16.2.4",
    "pino": "^9.9.5",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.66.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^22.18.13",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.10",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "uuid": "^14.0.0"
  }
}
