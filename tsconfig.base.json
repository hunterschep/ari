{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@ari/schemas": ["packages/schemas/src/index.ts"],
      "@ari/schemas/*": ["packages/schemas/src/*"],
      "@ari/shared": ["packages/shared/src/index.ts"],
      "@ari/shared/*": ["packages/shared/src/*"],
      "@ari/agents": ["packages/agents/src/index.ts"],
      "@ari/agents/*": ["packages/agents/src/*"],
      "@ari/integrations": ["packages/integrations/src/index.ts"],
      "@ari/integrations/*": ["packages/integrations/src/*"],
      "@ari/ui": ["packages/ui/src/index.ts"],
      "@ari/ui/*": ["packages/ui/src/*"],
      "@ari/config": ["packages/config/src/index.ts"],
      "@ari/logger": ["packages/logger/src/index.ts"]
    }
  }
}
